#!/usr/bin/make -f

include /usr/share/dpkg/pkg-info.mk

#export DH_VERBOSE=1
export RUSTUP_HOME=/tmp/rustup
export CARGO_HOME=/tmp/cargo_home
export CARGO_TARGET_DIR=/tmp/cargo
export CARGO_TARGET_TMPDIR=/tmp/cargo/tmp

BIN_NAME = uv
BIN_DESCRIPTION = "An extremely fast Python package and project manager"

%:
	dh $@

override_dh_auto_clean:
	mkdir -p $(CARGO_TARGET_DIR)
	mkdir -p $(CARGO_TARGET_TMPDIR)
	mkdir -p $(CARGO_HOME)
	rustup default stable
	dh_auto_clean

override_dh_auto_configure:
	cargo fetch

override_dh_auto_build:
	cargo build --release --package uv

override_dh_auto_install:
	mkdir -p debian/$(BIN_NAME)/usr/bin/
	install -m 755 $(CARGO_TARGET_DIR)/release/uv debian/$(BIN_NAME)/usr/bin/
	if [ -f $(CARGO_TARGET_DIR)/release/uvx ]; then \
		install -m 755 $(CARGO_TARGET_DIR)/release/uvx debian/$(BIN_NAME)/usr/bin/; \
	else \
		ln -s uv debian/$(BIN_NAME)/usr/bin/uvx; \
	fi

override_dh_installman:
	help2man \
		--name $(BIN_DESCRIPTION) \
		--no-info \
		--no-discard-stderr \
		--version-string $(DEB_VERSION_UPSTREAM) \
		--output debian/$(BIN_NAME).1 \
		debian/$(BIN_NAME)/usr/bin/$(BIN_NAME)
	dh_installman

override_dh_auto_test:
