#!/bin/sh
set -e
case "$1" in
configure)
	if ! getent passwd registry >/dev/null 2>&1; then
		adduser --quiet --system --group \
			--home /var/lib/registry --shell /usr/sbin/nologin \
			--no-create-home registry
	fi
	mkdir -p /var/lib/registry
	chown registry:registry /var/lib/registry
	chmod 0750 /var/lib/registry
	;;
esac
#DEBHELPER#
exit 0
