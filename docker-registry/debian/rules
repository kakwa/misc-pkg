#!/usr/bin/make -f
# -*- makefile -*-

export GOPROXY = https://proxy.golang.org
export GOSUMDB = sum.golang.org
export GO111MODULE = on
export CGO_ENABLED = 0

DEST = $$(pwd)/debian/@NAME@

PKG = github.com/distribution/distribution/v3

# For chroot builds without $HOME
ifeq ($(HOME),/nonexistent)
export HOME = /build
endif

%:
	dh $@

override_dh_auto_build:
	mkdir -p bin
	GOTOOLCHAIN=auto go build -buildmode=pie -trimpath \
		-ldflags "-extldflags=-Wl,-z,now -s -w -X $(PKG)/version.version=v@VERSION@ -X $(PKG)/version.revision=debian -X $(PKG)/version.mainpkg=$(PKG)" \
		-o bin/registry ./cmd/registry

override_dh_auto_install:
	mkdir -p $(DEST)/usr/bin
	install -m 755 bin/registry $(DEST)/usr/bin/registry

override_dh_auto_test:
